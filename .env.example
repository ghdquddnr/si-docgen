# si-docgen 설정 예시 — 복사해서 .env 로 사용 (.env 는 커밋 금지)
# 모델명은 LiteLLM 형식: https://docs.litellm.ai/docs/providers

# 기본: 로컬 Ollama (설치된 모델 확인: `ollama list`)
# e4b 권장 — 12b 는 구조화 출력 추론이 매우 느려(이 개발 PC 기준 600s 타임아웃) 사실상 사용 불가
SIDOCGEN_LLM_MODEL=ollama/gemma4:e4b  # 사전에 `ollama pull gemma4:e4b`
# SIDOCGEN_LLM_MODEL=ollama/gemma4:12b

# 상용 모델 예시 (전환 시 주석 해제 + API 키 설정)
# SIDOCGEN_LLM_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# 선택 설정 — 로컬 모델은 구조화 출력에도 80~100s 소요되므로 타임아웃 여유 있게
SIDOCGEN_LLM_TIMEOUT=300
# SIDOCGEN_LLM_API_BASE=http://localhost:11434
# SIDOCGEN_LLM_MAX_ATTEMPTS=3
