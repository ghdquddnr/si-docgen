{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "app.api.main:app", "--port", "8000", "--app-dir", "backend"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["pnpm", "-C", "frontend", "dev"],
      "port": 3000
    }
  ]
}
